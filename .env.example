# ── Datenbank ──────────────────────────────────────────────────────────────────
POSTGRES_DB=application_pal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:change-me-strong-password@application-pal-db:5432/application_pal

# ── Backend ────────────────────────────────────────────────────────────────────
PORT=3000
# Leer lassen → wird beim ersten Start automatisch generiert.
# WICHTIG: Setze einen eigenen Wert damit Sessions container-Neustarts überleben.
# Generieren mit: openssl rand -hex 32
JWT_SECRET=

# ── App URL ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8070
# Bei VPS/Server-Deployment: APP_URL=https://deine-domain.de
VITE_API_URL=/api
FRONTEND_PORT=5174

# ── Google Drive & Anmeldung (optional) ────────────────────────────────────────
# Ermöglicht: Mit Google anmelden + Google Drive in einem Schritt verbinden.
# Einrichtung: docs/google-setup.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_FRONTEND_URL=http://localhost:8070
GOOGLE_REDIRECT_URI=http://localhost:8070/api/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/documents

# ── E-Mail Recovery (optional) ─────────────────────────────────────────────────
# Ohne SMTP: Recovery-Code erscheint nur im Backend-Log (docker compose logs backend).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Gmail: App-Passwort unter myaccount.google.com/apppasswords erstellen
